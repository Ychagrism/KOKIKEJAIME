{
  "manifest_version": 3,
  "name": "FedEx CED Exception Helper",
  "version": "1.1",
  "description": "In-page overlay that parses FedEx order history and provides clear action steps.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://fedex-ced.lightning.force.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://fedex-ced.lightning.force.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "Exception codes.csv"],
      "matches": ["https://fedex-ced.lightning.force.com/*"]
    }
  ]
}
